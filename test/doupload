#!/bin/bash

# Performs an upload and retrieval test using the guppy client CLI.
#
# Usage: test/doupload [--database-url <url>]
#
# Options:
#   --database-url <url>  Use PostgreSQL instead of SQLite. The URL can either
#                         include a database name (e.g., postgres://localhost/mydb)
#                         or omit it (e.g., postgres://localhost), in which case a
#                         temporary database is created and dropped on exit.
#                         To use a specific schema, add ?search_path=<name> to the URL.
#
# The test will:
# 1. Check out Smelt, initialize it, and move into a container.
# 2. Create a new space
# 3. Upload some random data to the space
# 4. Retrieve the full data
# 5. Retrieve a subdirectory of the data
# 6. Reset the client and log in again
# 7. Retrieve the full data again
# 8. Verify that all retrieved data matches the original

# TODO: Postgres support is not yet ported to Smelt/Sprue

set -e
set -o pipefail


runGuppyContainer () {
  case $1 in
  down)
    echo "Taking down containers..."
    docker compose down
    echo "Removing volumes..."
    docker volume prune --force --all --filter "label=com.docker.compose.project=guppy-test"
    exit $?
    ;;
  shell)
    service="${2:-guppy}"
    echo "Starting a shell in the container..."
    docker compose run --rm --entrypoint="/bin/sh" "$service"
    exit $?
    ;;
  *)
		# Start up the `piri` services first to watch them.
    upServices $(docker compose config --services | grep piri- | sort)

    echo "🧹 Resetting data-dir"
    docker volume prune --force --all --filter "label=com.docker.compose.project=guppy-test" --filter "label=com.docker.compose.volume=guppy-data" >/dev/null

    [ -d smelt/.git ] || git clone https://github.com/storacha/smelt.git smelt

    echo "🏁 Initializing smelt"
    export SMELT_MANIFEST="$PWD/smelt-manifest.yml"
    (cd smelt && make init >/dev/null)

    # docker compose run --rm --entrypoint="true" guppy-doupload



    echo "🐳 Moving into the container..."
    echo
    docker compose run --rm --build --quiet-build guppy-doupload
    exit $?
    ;;
  esac
}

runTests () {
	# Teeing to /dev/fd/3 will show output on stdout while still capturing it.
	exec 3>&1

	# HTTPS is not available in Smelt, so allow insecure DID resolution.
	export GUPPY_NETWORK_INSECURE_DID_RESOLUTION=true

	account="racha@hen.house"

	echo
	echo "🏭 Generating random data"
	randdir --output "data/large-files" --size 50MB --min-file-size 10MB
	randdir --output "data/small-files" --size 5MB --min-file-size 100KB --max-file-size 1MB

	echo
	echo "🔐 Logging in as $account"

	# Log in
	guppy login "$account"

	echo
	echo "🎁 Generating new space"
	space=$(guppy space generate | tee /dev/fd/3)

	# (Currently not supported in Smelt/Sprue)
	# echo
	# echo "📜 Listing space info"
	# guppy space info "$space"

	echo
	echo "📤 Uploading data from data/ to space $space"
	guppy upload source add "$space" "data"
	rootCID=$(guppy upload "$space" | tee /dev/fd/3 | grep 'Upload completed successfully:' | awk '{print $4}')

	echo
	echo "🧐 Checking local upload state"
	guppy upload check "$space"
	echo "✅ Upload state passed checks!"

	echo
	echo "🕵 Verifying uploaded data is accessible and consistent"
	guppy verify "$rootCID"
	echo "✅ Uploaded data verified!"

	echo
	echo "📥 Retrieving data from space $space with root CID $rootCID to out1"
	guppy retrieve "$space" "$rootCID" "out1"

	echo
	echo "📥 Retrieving data from only subdir with root CID $rootCID to out2"
	guppy retrieve "$space" "$rootCID/small-files" "out2"

	# TODO: Re-login not working yet.

	# echo
	# echo "🔄 Resetting client"
	# guppy reset
	# echo "🔐 Logging in as $account again"

	# # Log in again
	# guppy login "$account"

	# echo
	# echo "📥 Retrieving data from space $space with root CID $rootCID to out3"
	# guppy retrieve "$space" "$rootCID" "out3"

	echo "↔️ Verifying retrieved data matches original"
	diff -r "data" "out1"
	diff -r "data/small-files" "out2"
	# diff -r "data" "out3"
	echo "✅ Retrieval verified!"

	# TODO:
	# jq -n \
	# 	--arg account "$account" \
	# 	--arg space "$space" \
	# 	--arg rootCID "$rootCID" \
	# 	--arg dataDir "$dataDir" \
	# 	--arg subdir "subdir" \
	# 	'{$account, $space, $rootCID, $dataDir, $subdir}' > "$sandbox/test-params.json"
}

upServices () {
	if ! command -v mprocs &> /dev/null; then
		echo "To see logs while waiting, install \`mprocs\`."
		docker compose up -d --wait "$@"
		return
	fi

	local mprocsPort
	local config

	mprocsPort=$((5000 + RANDOM % 1000))
	config=$(mktemp) && mv "$config" "$config.json" && config="$config.json"
	jq \
		'{
			server: "\($mprocsServer)",
			procs: {
				"Starting...": "docker compose up -d --wait \($ARGS.positional | join(" ")) && mprocs --server \"\($mprocsServer)\" --ctl \"{c: quit}\""
			} + ($ARGS.positional | INDEX(.[]; " " + .) | map_values({shell: "docker compose logs -f --no-log-prefix \(.)", stop: {"send-keys": ["<C-c>"]}}))
		}' \
		-n \
		--arg mprocsServer "127.0.0.1:$mprocsPort" \
		--args "$@" \
			>"$config"

	mprocs --config "$config"
	rm "$config"
}


# Bootstrap this script into a `guppy` service container.
if [[ -z "$IN_CONTAINER" ]]; then
  # Change to the directory of this script
  cd "$(dirname "$0")"

	runGuppyContainer "$@"
else
	runTests
fi

